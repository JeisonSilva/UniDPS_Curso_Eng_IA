{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "checkJs": true,
    "allowJs": true,
    "strict": false,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "*": ["node_modules/*"]
    }
  },
  "include": [
    "src/**/*.js",
    "machine-learning/**/*.js",
    "main.js",
    "gulpfile.js"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
